S_Btn.MouseButton1Click:Connect(function()
    local char = localPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    StealthActive = not StealthActive
    if StealthActive then
        FreezePos = char.HumanoidRootPart.CFrame
        S_Btn.Text = "ON"
        S_Btn.TextColor3 = Color3.fromRGB(255, 50, 50)
        
        -- カメラ固定用のダミーパーツ作成
        CamPart = Instance.new("Part", workspace)
        CamPart.Transparency = 1
        CamPart.Anchored = true
        CamPart.CanCollide = false
        CamPart.CFrame = FreezePos
        workspace.CurrentCamera.CameraSubject = CamPart
        
        -- キャラクターを地底へ飛ばして固定
        task.spawn(function()
            while StealthActive and char:FindFirstChild("HumanoidRootPart") do
                char.HumanoidRootPart.CFrame = CFrame.new(FreezePos.X, HIDE_Y, FreezePos.Z)
                char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.zero
                task.wait()
            end
        end)
    else
        S_Btn.Text = "OFF"
        S_Btn.TextColor3 = Color3.new(1, 1, 1)
        if CamPart then CamPart:Destroy() end
        char.HumanoidRootPart.CFrame = FreezePos
        workspace.CurrentCamera.CameraSubject = char.Humanoid
    end
end)

