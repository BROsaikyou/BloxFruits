local function startUnbreakable()
    local function hook(obj)
        if not obj then return end
        table.insert(UnbreakableConns, obj:GetAttributeChangedSignal("UnbreakableAll"):Connect(function()
            if UnbreakableActive and obj:GetAttribute("UnbreakableAll") ~= true then obj:SetAttribute("UnbreakableAll", true) end
        end))
        if UnbreakableActive then obj:SetAttribute("UnbreakableAll", true) end
    end
    table.insert(UnbreakableConns, localPlayer.CharacterAdded:Connect(hook))
    table.insert(UnbreakableConns, workspace.ChildAdded:Connect(function(child) if child.Name == localPlayer.Name then hook(child) end end))
    hook(localPlayer.Character); local f = workspace:FindFirstChild(localPlayer.Name) if f then hook(f) end
end
AddToggle(MainTab, "Unbreakable All", function(state)
    UnbreakableActive = state
    for _, v in pairs(UnbreakableConns) do v:Disconnect() end
    UnbreakableConns = {}
    if state then startUnbreakable() else if localPlayer.Character then localPlayer.Character:SetAttribute("UnbreakableAll", nil) end end
end)

