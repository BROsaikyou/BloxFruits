-- [[ サイレントエイム用ロジック（追加分） ]]
local AimState = { Target = nil, isHooked = false, Connection = nil }
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
local oldIndex = mt.__index

local function getNearest()
    local near, dist = nil, math.huge
    local myRoot = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local d = (myRoot.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d; near = p.Character.HumanoidRootPart end
        end
    end
    return near
end

local function EnableAimbot()
    if AimState.isHooked then return end
    setreadonly(mt, false)
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        if method == "FireServer" and AimState.Target then
            for i, v in ipairs(args) do if typeof(v) == "Vector3" then args[i] = AimState.Target.Position end end
            return oldNamecall(self, unpack(args))
        end
        return oldNamecall(self, ...)
    end)
    mt.__index = newcclosure(function(self, key)
        if key == "FireServer" then
            return newcclosure(function(remote, ...)
                local args = {...}
                if AimState.Target then for i, v in ipairs(args) do if typeof(v) == "Vector3" then args[i] = AimState.Target.Position end end end
                return oldNamecall(remote, unpack(args))
            end)
        end
        return oldIndex(self, key)
    end)
    setreadonly(mt, true)
    AimState.Connection = RunService.Heartbeat:Connect(function() AimState.Target = getNearest() end)
    AimState.isHooked = true
end

local function DisableAimbot()
    if not AimState.isHooked then return end
    setreadonly(mt, false)
    mt.__namecall = oldNamecall; mt.__index = oldIndex
    setreadonly(mt, true)
    if AimState.Connection then AimState.Connection:Disconnect() end
    AimState.Target = nil; AimState.isHooked = false
end
