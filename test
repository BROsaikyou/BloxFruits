-- ESPメインロジック (提供されたコードを最適化して組み込み)
local function createESP(player)
    if player == localPlayer then return end

    local Box = Drawing.new("Square")
    local Tracer = Drawing.new("Line")
    local NameL = Drawing.new("Text")
    local HealthL = Drawing.new("Text")
    local DistL = Drawing.new("Text")

    -- テキスト設定
    for _, txt in pairs({NameL, HealthL, DistL}) do
        txt.Size = (txt == NameL) and 24 or 20
        txt.Center = true
        txt.Outline = true
        txt.Visible = false
    end

    local function hideAll()
        Box.Visible = false; Tracer.Visible = false; NameL.Visible = false; HealthL.Visible = false; DistL.Visible = false
    end

    local connection
    connection = RunService.RenderStepped:Connect(function()
        if not player or not player.Parent then
            hideAll()
            Box:Remove(); Tracer:Remove(); NameL:Remove(); HealthL:Remove(); DistL:Remove()
            connection:Disconnect()
            return
        end

        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        
        if hrp and hum and hum.Health > 0 then
            local pos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)

            if onScreen then
                local teamColor = Color3.new(1, 1, 1)
                local teamName = (player.Team and player.Team.Name) or (player:FindFirstChild("Data") and player.Data:FindFirstChild("Team") and player.Data.Team.Value) or ""
                if string.find(teamName, "Pirate") then teamColor = Color3.fromRGB(255, 0, 0)
                elseif string.find(teamName, "Marine") then teamColor = Color3.fromRGB(0, 190, 255) end

                local head_pos = workspace.CurrentCamera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3, 0))
                local leg_pos = workspace.CurrentCamera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3.5, 0))
                local height = math.abs(head_pos.Y - leg_pos.Y)
                local width = height * 0.55

                -- 各種描画の更新 (ESP_Settingsを参照)
                Box.Visible = ESP_Settings.Box
                Box.Size = Vector2.new(width, height)
                Box.Position = Vector2.new(pos.X - width / 2, pos.Y - height / 2)
                Box.Color = teamColor
                Box.Thickness = 1

                Tracer.Visible = ESP_Settings.Tracer
                Tracer.From = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y)
                Tracer.To = Vector2.new(pos.X, pos.Y + (height / 2))
                Tracer.Color = teamColor

                NameL.Visible = ESP_Settings.Name
                NameL.Text = player.DisplayName or player.Name
                NameL.Position = Vector2.new(pos.X, pos.Y - (height / 2) - 30)
                NameL.Color = teamColor

                HealthL.Visible = ESP_Settings.Health
                HealthL.Text = "HP: " .. math.floor(hum.Health)
                HealthL.Position = Vector2.new(pos.X, pos.Y - (height / 2) - 55)
                HealthL.Color = Color3.fromRGB(0, 255, 0)

                DistL.Visible = ESP_Settings.Distance
                local d = math.floor((workspace.CurrentCamera.CFrame.Position - hrp.Position).Magnitude)
                DistL.Text = d .. "m"
                DistL.Position = Vector2.new(pos.X, pos.Y + (height / 2) + 10)
                DistL.Color = Color3.new(1, 1, 1)
            else
                hideAll()
            end
        else
            hideAll()
        end
    end)
end

