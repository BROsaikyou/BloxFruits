-- [[ サイレントエイム用ロジック（追加分） ]]
local AimState = { Target = nil, isHooked = false, Connection = nil }
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
local oldIndex = mt.__index

local function getNearest()
    local near, dist = nil, math.huge
    local myRoot = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local d = (myRoot.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then dist = d; near = p.Character.HumanoidRootPart end
        end
    end
    return near
end

local function EnableAimbot()
    if AimState.isHooked then return end
    AimState.isHooked = true
    setreadonly(mt, false)
    mt.__namecall = newcclosure(function(self, ...)
        local args = {...}
        local method = getnamecallmethod()
        if method == "FireServer" and self.Name == "RemoteEvent" then -- ゲームに合わせて調整が必要
            local t = getNearest()
            if t then args[1] = t.Position end
        end
        return oldNamecall(self, unpack(args))
    end)
    mt.__index = newcclosure(function(self, key)
        if key == "Hit" and self:IsA("Mouse") then
            local t = getNearest()
            if t then return t.CFrame end
        end
        return oldIndex(self, key)
    end)
    setreadonly(mt, true)
end

