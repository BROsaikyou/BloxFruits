-- [[ 2. スムーズドラッグ実装 ]]
local draggingHub, dragStartHub, startPosHub
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        local guiObjects = localPlayer.PlayerGui:GetGuiObjectsAtPosition(input.Position.X, input.Position.Y)
        local canDrag = true
        for _, obj in pairs(guiObjects) do
            if obj:IsA("TextButton") or obj:IsA("ScrollingFrame") or obj:IsA("TextBox") then
                if obj == MainFrame then canDrag = true else canDrag = false break end
            end
        end
        if canDrag then draggingHub = true; dragStartHub = input.Position; startPosHub = MainFrame.Position end
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if draggingHub and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStartHub
        MainFrame.Position = UDim2.new(startPosHub.X.Scale, startPosHub.X.Offset + delta.X, startPosHub.Y.Scale, startPosHub.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then draggingHub = false end end)

