local function CreateTab(name, isFirst)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 40); -- 高さを 45 から 40 に変更
    btn.BackgroundColor3 = isFirst and ACCENT_COLOR or Color3.fromRGB(30, 30, 30)
    btn.Text = name; btn.Font = Enum.Font.GothamBold;
    btn.TextSize = 16; btn.TextColor3 = Color3.fromRGB(255, 255, 255); btn.Parent = Sidebar
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local page = Instance.new("ScrollingFrame")
    page.Size = UDim2.new(1, -15, 1, -15);
    page.Position = UDim2.new(0, 8, 0, 8); page.BackgroundTransparency = 1; page.Visible = isFirst; page.AutomaticCanvasSize = Enum.AutomaticSize.Y; page.ScrollBarThickness = 2;
    page.Parent = Container
    Instance.new("UIListLayout", page).Padding = UDim.new(0, 8); table.insert(tabPages, page);
    table.insert(tabButtons, btn)
    btn.MouseButton1Click:Connect(function()
        for _, p in ipairs(tabPages) do p.Visible = false end
        for _, b in ipairs(tabButtons) do b.BackgroundColor3 = Color3.fromRGB(30, 30, 30) end
        page.Visible = true; btn.BackgroundColor3 = ACCENT_COLOR
    end)
    return page
end

