-- Unbreakable 機能
local function ApplyUnbreakable(char)
    if not UnbreakableActive then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        table.insert(UnbreakableConns, hum.HealthChanged:Connect(function(hp)
            if hp < hum.MaxHealth then hum.Health = hum.MaxHealth end
        end))
    end
end

AddToggle(scriptPage, "Unbreakable (HP)", function(state)
    UnbreakableActive = state
    if state then
        if localPlayer.Character then ApplyUnbreakable(localPlayer.Character) end
        table.insert(UnbreakableConns, localPlayer.CharacterAdded:Connect(ApplyUnbreakable))
    else
        for _, c in ipairs(UnbreakableConns) do c:Disconnect() end
        UnbreakableConns = {}
    end
end)

