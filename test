-- --- Combat 実行ループ ---
_G.FastAttackEnabled = false
_G.AttackRange = 60

local function IsAlive(char) return char and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 end
local function GetTargetsInRange(range)
    local char = localPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return {} end
    local targets = {}
    local folders = {workspace:FindFirstChild("Enemies"), Players}
    for _, f in ipairs(folders) do
        if f then
            local children = (f == Players) and f:GetPlayers() or f:GetChildren()
            for _, obj in ipairs(children) do
                local tChar = (f == Players) and obj.Character or obj
                if tChar and tChar ~= char and IsAlive(tChar) then
                    local hrp = tChar:FindFirstChild("HumanoidRootPart")
                    if hrp and (hrp.Position - char.HumanoidRootPart.Position).Magnitude <= range then table.insert(targets, tChar) end
                end
            end
        end
    end
    return targets
end

local function ExecuteAttack()
    local tool = localPlayer.Character and localPlayer.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    local targets = GetTargetsInRange(_G.AttackRange)
    if #targets == 0 then return end
    if tool:FindFirstChild("LeftClickRemote") then
        for i, t in ipairs(targets) do
            local hrp = t:FindFirstChild("HumanoidRootPart")
            if hrp then tool.LeftClickRemote:FireServer((hrp.Position - localPlayer.Character:GetPivot().Position).Unit, i) end
        end
    else
        local hitList = {}
        local lastPart
        for _, t in ipairs(targets) do
            if not t:GetAttribute("IsBoat") and t:FindFirstChild("Head") then table.insert(hitList, {t, t.Head}); lastPart = t.Head end
        end
        if lastPart then
            local net = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
            pcall(function() net["RE/RegisterAttack"]:FireServer(0.4); net["RE/RegisterHit"]:FireServer(lastPart, hitList) end)
        end
    end
end

task.spawn(function() while true do if _G.FastAttackEnabled then pcall(ExecuteAttack) end task.wait(0.1) end end)

_G.AutoRaceV4_Force = false
_G.AutoRaceV3_Ability = false
local AbilityCooldown = 0
local RaceAbils = {"Last Resort", "Agility", "Water Body", "Heavenly Blood", "Heightened Senses", "Energy Core", "Primordial Reign"}

RunService.Heartbeat:Connect(function(dt)
    local char = localPlayer.Character
    if not char then return end
    pcall(function()
        if _G.AutoRaceV4_Force then
            local energy = char:FindFirstChild("RaceEnergy")
            if energy and energy.Value >= 1 then
                local rt = char:FindFirstChild("RaceTransformed")
                if rt then rt.Value = false end
                ReplicatedStorage.Remotes.CommE:FireServer("ActivateAbility")
                local awk = localPlayer.Backpack:FindFirstChild("Awakening") or char:FindFirstChild("Awakening")
                if awk and awk:FindFirstChild("RemoteFunction") then awk.RemoteFunction:InvokeServer(true) end
            end
        end
        if _G.AutoRaceV3_Ability then
            if IsAlive(char) then
                local hasA = false
                for _,v in ipairs(RaceAbils) do if localPlayer.Backpack:FindFirstChild(v) or char:FindFirstChild(v) then hasA = true break end end
                if hasA then
                    AbilityCooldown = AbilityCooldown - dt
                    if AbilityCooldown <= 0 then ReplicatedStorage.Remotes.CommE:FireServer("ActivateAbility"); AbilityCooldown = 0.5 end
                end
            end
        end
    end)
end)

