local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local player = Players.LocalPlayer

local TARGET_PLACE_ID = 2753915549
if game.PlaceId ~= TARGET_PLACE_ID then
    player:Kick("ファーストシーで使用してください。")
    return
end

local function runUserTeamChange()
    local remotes = ReplicatedStorage:WaitForChild("Remotes", 10)
    local commF = remotes and remotes:WaitForChild("CommF_", 10)
    
    while true do
        local currentTeam = player.Team
        if currentTeam and (currentTeam.Name:find("Marine")) then
            break
        end

        if commF then
            pcall(function()
                commF:InvokeServer("SetTeam", "Marines")
            end)
        end
        task.wait(1)
    end
end

runUserTeamChange()

local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart", 15)
local humanoid = character:WaitForChild("Humanoid", 15)

task.wait(2)

local TARGET_POS = Vector3.new(5437, 111, 4765)
local MOVE_SPEED = 300
local ATTRIBUTE_NAME = "KenDodgesLeft"
local REMOTE_PATH = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("CommE")

task.spawn(function()
    while true do
        pcall(function()
            if REMOTE_PATH then
                REMOTE_PATH:FireServer("Ken", true)
            end
        end)
        task.wait(1)
    end
end)

local function moveToTarget()
    if not rootPart or not rootPart.Parent then return end

    local noclip = true
    local noclipConnection = RunService.Stepped:Connect(function()
        if noclip and character then
            for _, v in pairs(character:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end
    end)

    local distance = (rootPart.Position - TARGET_POS).Magnitude
    local duration = distance / MOVE_SPEED
    local tween = TweenService:Create(rootPart, TweenInfo.new(duration, Enum.EasingStyle.Linear), {CFrame = CFrame.new(TARGET_POS)})

    tween:Play()
    tween.Completed:Wait()
    
    noclip = false
    noclipConnection:Disconnect()
end

pcall(moveToTarget)

if rootPart and humanoid then
    rootPart.Anchored = true
    humanoid.WalkSpeed = 0
    humanoid.JumpPower = 0
end

task.wait(2)

if rootPart and humanoid then
    rootPart.Anchored = false
    humanoid.WalkSpeed = 16
    humanoid.JumpPower = 50
end

local stickConnection
stickConnection = RunService.Heartbeat:Connect(function()
    pcall(function()
        local enemyFolder = Workspace:FindFirstChild("Enemies")
        local target = enemyFolder and enemyFolder:FindFirstChild("Galley Captain")
        if target and target:FindFirstChild("HumanoidRootPart") and rootPart and not rootPart.Anchored then
            rootPart.CFrame = target.HumanoidRootPart.CFrame
        end
    end)
end)

local function serverHop()
    local api = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
    
    while task.wait(3) do
        local success, result = pcall(function()
            return HttpService:JSONDecode(game:HttpGet(api))
        end)
        
        if success and result and result.data then
            table.sort(result.data, function(a, b) return a.playing < b.playing end)
            
            for _, server in ipairs(result.data) do
                if server.id ~= game.JobId and server.playing < server.maxPlayers then
                    pcall(function()
                        TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, player)
                    end)
                    task.wait(1)
                end
            end
        end
    end
end

player:GetAttributeChangedSignal(ATTRIBUTE_NAME):Connect(function()
    if player:GetAttribute(ATTRIBUTE_NAME) == 0 then
        if stickConnection then stickConnection:Disconnect() end
        serverHop()
    end
end)

if player:GetAttribute(ATTRIBUTE_NAME) == 0 then
    serverHop()
end
